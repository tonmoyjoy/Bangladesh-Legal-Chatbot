# ─────────────────────────────────────────────────────────────────────────────
#  Bangladesh Legal Chatbot — Environment Configuration
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key (free at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# LLM model served by Groq
# Options: llama-3.1-8b-instant | llama-3.3-70b-versatile | openai/gpt-oss-120b
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace embedding model (runs locally — no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB persistence directory
CHROMA_DIR=./vectorstore/chroma_db

# PDF source directory
PDF_DIR=./data

# Chunking parameters
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Number of chunks to retrieve per query
TOP_K=5
